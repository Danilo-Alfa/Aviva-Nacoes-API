# ==============================================
# CONFIGURAÇÕES DO SERVIDOR
# ==============================================
PORT=3001
NODE_ENV=development

# URL do frontend (para CORS)
FRONTEND_URL=http://localhost:5173

# ==============================================
# SUPABASE
# ==============================================
SUPABASE_URL=https://seu-projeto.supabase.co
SUPABASE_SERVICE_KEY=sua_service_key_aqui

# ==============================================
# AUTENTICAÇÃO
# ==============================================
# Senha de admin (mesma do frontend)
ADMIN_PASSWORD=sua_senha_admin

# API Key para automações externas
API_KEY=sua_api_key_segura_aqui

# ==============================================
# SWAGGER (Documentação)
# ==============================================
SWAGGER_ENABLED=true

# ==============================================
# TELEGRAM (notificação do Fale Conosco)
# ==============================================
# Token do bot, criado com o @BotFather no Telegram
TELEGRAM_BOT_TOKEN=seu_bot_token_aqui
# ID do chat/grupo que recebe as notificações
# (obtido em https://api.telegram.org/bot<TOKEN>/getUpdates após enviar uma mensagem ao bot)
TELEGRAM_CHAT_ID=seu_chat_id_aqui
